---
interface Props {
  title: string
  subtitle?: string
}

const { title, subtitle } = Astro.props
---

<div class="bg-linear-to-t from-violet-500 to-transparent">
  <div class="mx-auto w-full bg-fixed">
    <header class="mx-auto w-full max-w-screen-xl px-3 py-10">
      <h1
        class="font-mono text-4xl font-bold tracking-widest text-white uppercase md:text-5xl lg:text-7xl"
      >
        {title}
      </h1>

      <p class="cmyk text-white md:text-xl">{subtitle}</p>
    </header>
  </div>
</div>
